/*
========================================================================================
    nextflow.config — Configuration principale du pipeline sc10x
========================================================================================
    Profiles disponibles :
      -profile docker       → Exécution locale avec Docker
      -profile singularity  → Exécution HPC avec Singularity
      -profile slurm        → Soumission SLURM (combinable avec singularity)
      -profile test         → Données de test (dry-run validation)
========================================================================================
*/

// ========================================================================================
// PARAMÈTRES GLOBAUX (surchargeables via CLI)
// ========================================================================================

params {

    // --- Entrées ---
    input_type        = 'fastq'          // 'bcl' ou 'fastq'
    input_dir         = null             // Dossier BCL ou dossier racine des FASTQ
    sample_sheet      = null             // Requis uniquement en mode BCL
    genome_reference  = null             // Chemin vers le génome Cell Ranger (pré-buildé)

    // --- Sorties ---
    output_dir        = "${launchDir}/results"

    // --- Ressources Cell Ranger ---
    localcores        = 16               // Nombre de CPU alloués à Cell Ranger
    localmemory       = 64              // RAM allouée en GB

    // --- Options Cell Ranger count ---
    chemistry         = 'auto'           // ex: 'SC3Pv3', 'SC5P-PE', 'auto'
    expect_cells      = 5000             // Nombre de cellules attendues par sample
    include_introns   = true             // Inclure les introns (pre-mRNA)
    force_cells       = null             // Forcer un nombre de cellules (optionnel)

    // --- Options MultiQC ---
    multiqc_config    = "${projectDir}/assets/multiqc_config.yaml"
    multiqc_title     = 'sc10x Pipeline QC Report'

    // --- Traçabilité ---
    enable_conda      = false            // Conda désactivé (utiliser Docker/Singularity)

    // --- Métadonnées pipeline ---
    pipeline_version  = '1.0.0'
    min_nextflow_version = '23.10.0'
}

// ========================================================================================
// VALIDATION DE LA VERSION NEXTFLOW
// ========================================================================================

if (nextflow.version.toString().tokenize('.').collect { it.toInteger() } <
    params.min_nextflow_version.tokenize('.').collect { it.toInteger() }) {
    error "Ce pipeline requiert Nextflow >= ${params.min_nextflow_version}. " +
          "Version courante : ${nextflow.version}. Veuillez mettre à jour Nextflow."
}

// ========================================================================================
// CONFIGURATION PAR DÉFAUT DES PROCESS
// ========================================================================================

process {

    // Politique de reprise sur erreur
    errorStrategy = { task.exitStatus in [130, 137, 139, 143] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // Ressources par défaut (écrasées par les labels ci-dessous)
    cpus   = 2
    memory = '8.GB'
    time   = '2.h'

    // -----------------------------------------------------------------------
    // LABELS DE RESSOURCES (utilisés dans les modules)
    // -----------------------------------------------------------------------

    withLabel: 'process_low' {
        cpus   = 2
        memory = '8.GB'
        time   = '2.h'
    }

    withLabel: 'process_medium' {
        cpus   = 8
        memory = '32.GB'
        time   = '6.h'
    }

    withLabel: 'process_high' {
        cpus   = { params.localcores }
        memory = { "${params.localmemory}.GB" }
        time   = '24.h'
    }

    withLabel: 'process_high_memory' {
        cpus   = { params.localcores }
        memory = { "${params.localmemory * 2}.GB" }
        time   = '48.h'
    }

    // -----------------------------------------------------------------------
    // CONTAINERS PAR PROCESS (versions fixées)
    // -----------------------------------------------------------------------

    withName: 'CELLRANGER_MKFASTQ' {
        container = 'nfcore/cellranger:7.2.0'
    }

    withName: 'CELLRANGER_COUNT' {
        container = 'nfcore/cellranger:7.2.0'
    }

    withName: 'MULTIQC' {
        container = 'quay.io/biocontainers/multiqc:1.21--pyhdfd78af_0'
    }
}

// ========================================================================================
// PROFILS D'EXÉCUTION
// ========================================================================================

profiles {

    // -----------------------------------------------------------------------
    // PROFIL DOCKER (développement / CI)
    // -----------------------------------------------------------------------
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        docker.userEmulation   = true
        singularity.enabled    = false
        conda.enabled          = false

        process {
            // Montage automatique du répertoire de travail
            containerOptions   = "--volume ${launchDir}:${launchDir}"
        }
    }

    // -----------------------------------------------------------------------
    // PROFIL SINGULARITY (HPC)
    // -----------------------------------------------------------------------
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.runOptions = "--bind ${launchDir}:${launchDir}"
        docker.enabled         = false
        conda.enabled          = false

        // Cache des images Singularity (évite les re-téléchargements)
        singularity.cacheDir   = "${launchDir}/.singularity_cache"
    }

    // -----------------------------------------------------------------------
    // PROFIL SLURM (soumission HPC via SLURM)
    // Combiner avec singularity : -profile slurm,singularity
    // -----------------------------------------------------------------------
    slurm {
        process {
            executor       = 'slurm'
            queue          = 'normal'         // Partition SLURM — à adapter
            clusterOptions = '--account=myproject'  // Compte HPC — à adapter

            withLabel: 'process_low' {
                queue  = 'short'
                time   = '2.h'
            }
            withLabel: 'process_medium' {
                queue  = 'normal'
                time   = '6.h'
            }
            withLabel: 'process_high' {
                queue  = 'bigmem'
                time   = '24.h'
            }
            withLabel: 'process_high_memory' {
                queue  = 'bigmem'
                time   = '48.h'
            }
        }

        executor {
            name           = 'slurm'
            queueSize      = 50              // Nombre max de jobs simultanés
            submitRateLimit = '10/1min'      // Limite de soumission
            pollInterval   = '30 sec'
            jobName        = { "sc10x_${task.name}_${task.hash}" }
        }
    }

    // -----------------------------------------------------------------------
    // PROFIL TEST (validation du pipeline sans données réelles)
    // -----------------------------------------------------------------------
    test {
        params {
            input_type       = 'fastq'
            input_dir        = "${projectDir}/test_data/fastq"
            output_dir       = "${launchDir}/test_results"
            genome_reference = "${projectDir}/test_data/genome_ref"
            sample_sheet     = "${projectDir}/test_data/sample_sheet.csv"
            localcores       = 4
            localmemory      = 16
            expect_cells     = 500
        }

        process {
            cpus   = 4
            memory = '16.GB'
            time   = '2.h'
        }
    }
}

// ========================================================================================
// RAPPORTS ET TRAÇABILITÉ
// ========================================================================================

timeline {
    enabled   = true
    overwrite = true
    file      = "${launchDir}/pipeline_timeline.html"
}

report {
    enabled   = true
    overwrite = true
    file      = "${launchDir}/pipeline_report.html"
}

trace {
    enabled        = true
    overwrite      = true
    file           = "${launchDir}/pipeline_trace.txt"
    fields         = 'task_id,hash,native_id,process,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar'
}

dag {
    enabled   = true
    overwrite = true
    file      = "${launchDir}/pipeline_dag.html"
}

// ========================================================================================
// CONFIGURATION GLOBALE DU MOTEUR NEXTFLOW
// ========================================================================================

manifest {
    name            = 'sc10x_pipeline'
    author          = 'Bioinformatics Team'
    homePage        = 'https://github.com/myorg/sc10x_pipeline'
    description     = 'Pipeline Single-Cell 10x Genomics (BCL/FASTQ → Cell Ranger → MultiQC)'
    mainScript      = 'main.nf'
    nextflowVersion = ">=23.10.0"
    version         = '1.0.0'
}

// Désactivation du cache des plugins par défaut
// pour garantir la reproductibilité entre exécutions
plugins {
    id 'nf-validation@1.1.3'
}
